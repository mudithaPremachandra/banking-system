# =============================================================================
# BANKING SYSTEM — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in the values.
# In Docker Compose, these are passed via env_file directive.
#
# OWNER: Muditha (DevOps), Kasunara (DBA for DB vars), Geethika (SMTP vars)
# =============================================================================

# --- PostgreSQL (Kasunara) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Database URLs (Kasunara — one per service, all pointing to same PostgreSQL instance) ---
AUTH_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/auth_db
ACCOUNT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/account_db
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/notification_db

# --- JWT (Sandun — Auth Service issues tokens; Gateway + Account Service verify them) ---
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- SMTP / Email (Geethika — Notification Service sends OTP emails) ---
# For development, use Ethereal: https://ethereal.email/ (create a free account)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user@ethereal.email
SMTP_PASS=your-ethereal-password
SMTP_FROM=noreply@bankingsystem.dev

# --- Service URLs (used for inter-service REST calls inside Docker network) ---
NOTIFICATION_SERVICE_URL=http://notification-service:3003
AUTH_SERVICE_URL=http://auth-service:3001
ACCOUNT_SERVICE_URL=http://account-service:3002
